{
  "name": "@ouroboros/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "better-auth generate --config src/shared/auth/auth.ts --output src/shared/database/schema/auth.schema.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@ouroboros/contracts": "workspace:*",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nestjs-zod": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@ouroboros/typescript-config": "workspace:*",
    "@swc/core": "^1.10.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.10"
  }
}
