{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Ouroboros NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "lib": ["ES2023"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "verbatimModuleSyntax": false,
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "incremental": true,
    "types": ["node"]
  }
}
